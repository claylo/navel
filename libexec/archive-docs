#!/usr/bin/env bash
set -euo pipefail

# archive-docs — Submit changed documentation files to the Internet Archive
# via the Save Page Now 2 (SPN2) API.
#
# Usage:
#   archive-docs <file1.md> [file2.md ...]
#   echo "overview.md quickstart.md" | xargs archive-docs
#
# Environment:
#   IA_ACCESS_KEY    Internet Archive S3 access key (required)
#   IA_SECRET_KEY    Internet Archive S3 secret key (required)
#
# SPN2 docs: https://docs.google.com/document/d/1Nsv52MvSjbLb2PCpHlat0gkzw0EvtSgpKHu4mk0MnrA
#
# Optimized for speed per SPN2 tips:
#   - force_get=1        plain text files, no headless browser needed
#   - js_behavior_timeout=0  no JS to execute
#   - skip_first_archive=1   we don't need first-capture metadata

BASE_URL="https://code.claude.com/docs/en"
SPN2_URL="https://web.archive.org/save"
SPN2_STATUS_URL="https://web.archive.org/save/status"

REPO_ROOT="${NAVEL_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
LOG_DIR="${REPO_ROOT}/logs"
mkdir -p "$LOG_DIR"
ARCHIVE_LOG="${LOG_DIR}/archive-docs.jsonl"

die() { echo "error: $*" >&2; exit 1; }

[[ -n "${IA_ACCESS_KEY:-}" ]] || die "IA_ACCESS_KEY not set"
[[ -n "${IA_SECRET_KEY:-}" ]] || die "IA_SECRET_KEY not set"
[[ $# -gt 0 ]] || die "usage: archive-docs <file1.md> [file2.md ...]"

AUTH_HEADER="Authorization: LOW ${IA_ACCESS_KEY}:${IA_SECRET_KEY}"

# Check available session slots, wait if full.
# SPN2 returns: {"available":N,"processing":M}
wait_for_slot() {
  local max_wait=120  # give up after 2 minutes
  local waited=0
  while [[ $waited -lt $max_wait ]]; do
    local user_status
    user_status=$(curl -s -H "Accept: application/json" \
      -H "$AUTH_HEADER" \
      "${SPN2_STATUS_URL}/user?_t=$(date +%s)" 2>/dev/null) || true
    local available
    available=$(echo "$user_status" | jq -r '.available // 0' 2>/dev/null)
    if [[ "$available" -gt 0 ]] 2>/dev/null; then
      return 0
    fi
    local processing
    processing=$(echo "$user_status" | jq -r '.processing // "?"' 2>/dev/null)
    echo "    waiting for slot (${processing} processing, waited ${waited}s)..."
    sleep 10
    waited=$((waited + 10))
  done
  echo "    timed out waiting for session slot"
  return 1
}

submitted=0
failed=0
now=$(date -u +%Y-%m-%dT%H:%M:%SZ)

for file in "$@"; do
  slug="${file%.md}"
  url="${BASE_URL}/${slug}.md"

  # Wait for an available session slot before submitting
  if ! wait_for_slot; then
    echo "  skipped:  ${slug}.md (no session slots after 2m)"
    failed=$((failed + 1))
    jq -nc --arg ts "$now" --arg slug "$slug" --arg url "$url" \
      --arg outcome "skipped" --arg message "session slot timeout" \
      '{ts:$ts, slug:$slug, url:$url, http_status:"000", outcome:$outcome,
        message:$message, resp_headers:[], resp_body:null}' >> "$ARCHIVE_LOG"
    continue
  fi

  # Capture response headers + body
  header_file=$(mktemp)
  response=$(curl -s -X POST \
    -D "$header_file" \
    -H "Accept: application/json" \
    -H "$AUTH_HEADER" \
    -d "url=${url}&force_get=1&js_behavior_timeout=0&skip_first_archive=1&if_not_archived_within=43200" \
    "$SPN2_URL" 2>&1) || true

  http_status=$(head -1 "$header_file" | grep -oE '[0-9]{3}' | head -1 || echo "000")
  resp_headers=$(sed '1d' "$header_file" | tr -d '\r' | jq -Rs 'split("\n") | map(select(length > 0))' 2>/dev/null || echo '[]')
  rm -f "$header_file"

  # Parse response
  job_id=$(echo "$response" | jq -r '.job_id // empty' 2>/dev/null)
  status_ext=$(echo "$response" | jq -r '.status_ext // empty' 2>/dev/null)
  message=$(echo "$response" | jq -r '.message // empty' 2>/dev/null)

  if [[ -n "$job_id" ]]; then
    echo "  archived: ${slug}.md (job: ${job_id})"
    submitted=$((submitted + 1))
    outcome="submitted"
  else
    error="${message:-${status_ext:-unknown}}"
    echo "  skipped:  ${slug}.md (${error})"
    failed=$((failed + 1))
    outcome="skipped"
  fi

  # Log full request/response for analysis
  jq -nc \
    --arg ts "$now" \
    --arg slug "$slug" \
    --arg url "$url" \
    --arg http_status "$http_status" \
    --arg outcome "$outcome" \
    --arg job_id "${job_id:-}" \
    --arg status_ext "${status_ext:-}" \
    --arg message "${message:-}" \
    --argjson resp_headers "$resp_headers" \
    --argjson resp_body "$(echo "$response" | jq -c '.' 2>/dev/null || echo 'null')" \
    '{ts:$ts, slug:$slug, url:$url, http_status:$http_status, outcome:$outcome,
      job_id:$job_id, status_ext:$status_ext, message:$message,
      resp_headers:$resp_headers, resp_body:$resp_body}' >> "$ARCHIVE_LOG"

  # Brief pause between requests — the slot check provides the main throttle
  if [[ $# -gt 1 ]]; then
    sleep 2
  fi
done

echo ""
echo "Archive: ${submitted} submitted, ${failed} skipped"
echo "  Log: ${ARCHIVE_LOG}"
