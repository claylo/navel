#!/usr/bin/env bash
set -euo pipefail

# Build pipeline for creating a Dash docset from Claude Code docs.
#
# Usage:
#   navel dash                      Build the docset (render → localize → assemble)
#   navel dash clean                Remove all build artifacts
#   navel dash --with-remote-fonts  Keep @font-face blocks (Anthropic fonts, local use only)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
NAVEL_HOME="${NAVEL_HOME:-$REPO_ROOT}"

# shellcheck source=_portable.sh
. "$SCRIPT_DIR/_portable.sh"

REPORTS_DIR="${NAVEL_REPORTS_DIR:-$(_reports_dir "$REPO_ROOT")}"
export REPO_ROOT NAVEL_HOME NAVEL_REPORTS_DIR="$REPORTS_DIR"

DASH_DIR="$REPO_ROOT/dash"
BUILD_HTML="$NAVEL_HOME/build/_html"
BUILD_DIR="$NAVEL_HOME/build"
DOCS_DIR="$NAVEL_HOME/docs"

die() { echo "error: $*" >&2; exit 1; }

cmd_clean() {
  echo "Cleaning build artifacts..."
  rm -rf "$BUILD_DIR"
  echo "  Removed build/"
}

cmd_build() {
  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --with-version-number) export WITH_VERSION_NUMBER=1; shift ;;
      --with-remote-fonts)   export WITH_REMOTE_FONTS=1; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  # Preflight checks
  [[ -d "$DOCS_DIR" ]] || die "no docs found — run 'navel docs sync' first"

  local md_count
  md_count=$(ls "$DOCS_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ')
  [[ "$md_count" -gt 0 ]] || die "no .md files in docs/"

  [[ -d "$REPO_ROOT/node_modules" ]] || die "node_modules missing — run 'npm install' in $(cd "$REPO_ROOT" && pwd)"

  command -v node >/dev/null || die "node not found in PATH"
  command -v sqlite3 >/dev/null || die "sqlite3 not found in PATH"

  mkdir -p "$BUILD_HTML"

  [[ -f "$REPORTS_DIR/nav.json" ]] || die "nav.json missing from $REPORTS_DIR — run 'navel docs sync' first"

  echo "==> Rendering HTML from docs..."
  node "$SCRIPT_DIR/js/dash-render.mjs"

  echo ""
  echo "==> Localizing external images..."
  node "$SCRIPT_DIR/js/localize-images.mjs"

  echo ""
  echo "==> Fixing mismatched image formats..."
  node "$SCRIPT_DIR/fix-image-formats" "$BUILD_HTML/images"

  echo ""
  echo "==> Assembling docset..."
  "$SCRIPT_DIR/build-docset"
}

case "${1:-}" in
  clean) cmd_clean ;;
  --*)   cmd_build "$@" ;;
  "")    cmd_build ;;
  *)     die "usage: navel dash [clean] [--with-version-number] [--with-remote-fonts]" ;;
esac
