#!/usr/bin/env bash
set -euo pipefail

# Build pipeline for creating a PDF from Claude Code docs.
#
# Usage:
#   navel pdf              Build the PDF (prep → compile)
#   navel pdf prep         Render intermediates only (build/_md + build/_typ)
#   navel pdf compile      Compile build/_typ → PDF (skips render)
#   navel pdf clean        Remove PDF build artifacts
#
# Options:
#   --print                Print-ready output: white background, alternating
#                          verso/recto running headers. Default is screen mode
#                          (cream background, consistent headers).

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
NAVEL_HOME="${NAVEL_HOME:-$REPO_ROOT}"
export REPO_ROOT NAVEL_HOME

PDF_DIR="$REPO_ROOT/pdf"
BUILD_TYPST="$NAVEL_HOME/build/_typ"
BUILD_MD="$NAVEL_HOME/build/_md"
BUILD_DIR="$NAVEL_HOME/build"
DOCS_DIR="$NAVEL_HOME/docs"
FONTS_DIR="$NAVEL_HOME/pdf/fonts"

die() { echo "error: $*" >&2; exit 1; }

# Copy Typst templates to NAVEL_HOME when running under Homebrew
# (Cellar is read-only; Typst relative paths need templates alongside data)
ensure_templates() {
  if [[ "$NAVEL_HOME" != "$REPO_ROOT" ]]; then
    mkdir -p "$NAVEL_HOME/pdf"
    cp "$PDF_DIR/main.typ" "$PDF_DIR/template.typ" "$PDF_DIR/callouts.typ" "$NAVEL_HOME/pdf/"
    [[ -d "$PDF_DIR/icons" ]] && cp -R "$PDF_DIR/icons" "$NAVEL_HOME/pdf/"
  fi
}

cmd_clean() {
  echo "Cleaning PDF build artifacts..."
  rm -rf "$BUILD_TYPST" "$BUILD_MD"
  rm -f "$BUILD_DIR/claude-code-docs.pdf"
  echo "  Removed build/_typ/, build/_md/, and build/claude-code-docs.pdf"
}

ensure_fonts() {
  mkdir -p "$FONTS_DIR"

  # Font sources: Anthropic (proprietary, embedded only) + JetBrains Mono (OFL)
  local anthro_base="https://assets.claude.ai/Fonts"
  local jb_base="https://github.com/JetBrains/JetBrainsMono/raw/master/fonts/ttf"
  local -a font_urls=(
    "$anthro_base/AnthropicSans-Text-Regular-Static.otf"
    "$anthro_base/AnthropicSans-Text-Medium-Static.otf"
    "$anthro_base/AnthropicSans-Text-Semibold-Static.otf"
    "$anthro_base/AnthropicSans-Text-Bold-Static.otf"
    "$anthro_base/AnthropicSans-Text-RegularItalic-Static.otf"
    "$anthro_base/AnthropicSans-Text-MediumItalic-Static.otf"
    "$anthro_base/AnthropicSans-Text-SemiboldItalic-Static.otf"
    "$anthro_base/AnthropicSans-Text-BoldItalic-Static.otf"
    "$anthro_base/AnthropicSerif-Display-Regular-Static.otf"
    "$anthro_base/AnthropicSerif-Display-Medium-Static.otf"
    "$anthro_base/AnthropicSerif-Display-Semibold-Static.otf"
    "$anthro_base/AnthropicSerif-Display-Bold-Static.otf"
    "$anthro_base/AnthropicSerif-Display-RegularItalic-Static.otf"
    "$jb_base/JetBrainsMono-Regular.ttf"
    "$jb_base/JetBrainsMono-Bold.ttf"
    "$jb_base/JetBrainsMono-Italic.ttf"
    "$jb_base/JetBrainsMono-BoldItalic.ttf"
  )

  local need_download=false
  for url in "${font_urls[@]}"; do
    local f="${url##*/}"
    if [[ ! -f "$FONTS_DIR/$f" ]]; then
      need_download=true
      break
    fi
  done

  if $need_download; then
    echo "==> Downloading fonts (embedded in PDF, not distributed)..."
    for url in "${font_urls[@]}"; do
      local f="${url##*/}"
      if [[ ! -f "$FONTS_DIR/$f" ]]; then
        printf "  %s" "$f"
        if curl -sL -o "$FONTS_DIR/$f" "$url"; then
          echo " ✓"
        else
          echo " FAILED"
        fi
      fi
    done
  fi
}

cmd_prep() {
  # Preflight checks
  [[ -d "$DOCS_DIR" ]] || die "no docs found — run 'navel docs sync' first"

  local md_count
  md_count=$(ls "$DOCS_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ')
  [[ "$md_count" -gt 0 ]] || die "no .md files in docs/"

  [[ -d "$REPO_ROOT/node_modules" ]] || die "node_modules missing — run 'npm install' in $(cd "$REPO_ROOT" && pwd)"

  command -v node >/dev/null || die "node not found — install via: brew install node"

  [[ -f "$NAVEL_HOME/reports/nav.json" ]] || die "reports/nav.json missing — run 'navel docs sync' first"

  mkdir -p "$BUILD_TYPST"

  ensure_templates
  ensure_fonts

  echo "==> Rendering intermediates from docs..."
  node "$SCRIPT_DIR/js/pdf-render.mjs"

  echo ""
  echo "Prep complete. Intermediate files:"
  echo "  build/_md/    — clean markdown ($(ls "$BUILD_MD"/*.md 2>/dev/null | wc -l | tr -d ' ') files)"
  echo "  build/_typ/ — Typst markup (pages/ + pages.typ)"
  echo ""
  echo "Run 'navel pdf compile' when ready."
}

cmd_compile() {
  [[ -f "$BUILD_TYPST/pages.typ" ]] || die "build/_typ/pages.typ not found — run 'navel pdf prep' first"

  command -v typst >/dev/null || die "typst not found — install via: brew install typst (or cargo install typst-cli)"

  ensure_templates
  ensure_fonts

  local typst_inputs=()
  if [[ "$PRINT_MODE" == "true" ]]; then
    typst_inputs+=(--input print=true)
    echo "==> Compiling PDF (print mode)..."
  else
    echo "==> Compiling PDF..."
  fi

  typst compile \
    --root "$NAVEL_HOME" \
    --font-path "$FONTS_DIR" \
    "${typst_inputs[@]}" \
    "$NAVEL_HOME/pdf/main.typ" \
    "$BUILD_DIR/claude-code-docs.pdf"

  local pdf_size
  pdf_size=$(du -sh "$BUILD_DIR/claude-code-docs.pdf" | cut -f1)
  echo ""
  echo "Done: build/claude-code-docs.pdf ($pdf_size)"
  echo "  open build/claude-code-docs.pdf"
}

cmd_build() {
  cmd_prep
  cmd_compile
}

# ── Parse flags ────────────────────────────────────────────────────────

PRINT_MODE="false"
args=()
for arg in "$@"; do
  case "$arg" in
    --print) PRINT_MODE="true" ;;
    *)       args+=("$arg") ;;
  esac
done

case "${args[0]:-}" in
  clean)   cmd_clean ;;
  prep)    cmd_prep ;;
  compile) cmd_compile ;;
  "")      cmd_build ;;
  *)       die "usage: navel pdf [--print] [prep|compile|clean]" ;;
esac
