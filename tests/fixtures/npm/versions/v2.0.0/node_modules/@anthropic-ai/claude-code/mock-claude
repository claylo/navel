#!/usr/bin/env bash
# Mock claude binary for v2.0.0 test fixture
# Responds to --help for top-level and subcommands

case "$*" in
  "--help"|"-h")
    cat <<'EOF'
Usage: claude [options] [command] [prompt]

Claude Code v2.0.0

Options:
  -p, --print        Print response and exit
  -c, --continue     Continue the most recent conversation
  -h, --help         Display help for command
  -v, --version      Output the version number

Commands:
  auth               Manage authentication
  mcp                Configure and manage MCP servers
EOF
    ;;
  "auth --help"|"auth -h")
    cat <<'EOF'
Usage: claude auth [options] [command]

Manage authentication

Options:
  -h, --help        Display help for command

Commands:
  login [options]   Sign in to your Anthropic account
  logout            Log out from your Anthropic account
  status            Show authentication status
  help [command]    display help for command
EOF
    ;;
  "auth login --help"|"auth login -h")
    cat <<'EOF'
Usage: claude auth login [options]

Sign in to your Anthropic account

Options:
  --method <method>  Authentication method (choices: "oauth", "api-key")
  -h, --help         Display help for command
EOF
    ;;
  "auth logout --help"|"auth logout -h"|"auth status --help"|"auth status -h")
    cat <<'EOF'
Usage: claude auth subcommand [options]

Options:
  -h, --help        Display help for command
EOF
    ;;
  "mcp --help"|"mcp -h")
    cat <<'EOF'
Usage: claude mcp [options] [command]

Configure and manage MCP servers

Options:
  -h, --help        Display help for command

Commands:
  add [options] <name>    Add an MCP server
  list                    List configured MCP servers
  remove <name>           Remove an MCP server
  help [command]          display help for command
EOF
    ;;
  "mcp add --help"|"mcp add -h")
    cat <<'EOF'
Usage: claude mcp add [options] <name>

Add an MCP server

Options:
  -s, --scope <scope>  Scope (choices: "user", "project")
  -h, --help           Display help for command
EOF
    ;;
  "mcp list --help"|"mcp list -h"|"mcp remove --help"|"mcp remove -h")
    cat <<'EOF'
Usage: claude mcp subcommand [options]

Options:
  -h, --help        Display help for command
EOF
    ;;
  *)
    echo "unknown: $*" >&2
    exit 1
    ;;
esac
